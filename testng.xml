<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Suite" parallel="Methods" thread-count="4" preserve-order="false">
    <listeners>
        <listener class-name="com.saucedemo.listeners.TestListener"/>
    </listeners>

    <test name="ChromeTests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.saucedemo.tests.SauceDemoLoginTest"/>
           <class name="com.saucedemo.tests.SauceDemoCartCheckoutTest"/> 
        </classes>
    </test>

    <test name="FirefoxTests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.saucedemo.tests.SauceDemoLoginTest"/>
            <class name="com.saucedemo.tests.SauceDemoCartCheckoutTest"/>
        </classes>
    </test>
</suite>
